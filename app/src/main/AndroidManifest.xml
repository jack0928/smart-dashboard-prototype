<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 이 앱은 자동차(Android Automotive OS) 전용임을 선언.
         이 한 줄이 일반 폰 앱과 차량 앱을 구분하는 핵심입니다. -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="true" />

    <!-- 차량 데이터를 읽기 위한 권한들.
         Pleos 의 Vehicle SDK 도 내부적으로 이런 차량 권한 위에서 동작합니다. -->
    <uses-permission android:name="android.car.permission.CAR_SPEED" />
    <uses-permission android:name="android.car.permission.CAR_ENERGY" />
    <uses-permission android:name="android.car.permission.CAR_POWERTRAIN" />
    <uses-permission android:name="android.car.permission.CAR_EXTERIOR_ENVIRONMENT" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_menu_compass"
        android:label="@string/app_name"
        android:theme="@style/Theme.PleosDashboard">

        <!-- android.car 라이브러리를 런타임에 연결.
             required=false : 혹시 없는 기기에서도 설치는 되도록 (안전장치) -->
        <uses-library
            android:name="android.car"
            android:required="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- 주행 중에도 표시 가능한 화면임을 표시 (차량 앱 권장 메타데이터) -->
            <meta-data
                android:name="distractionOptimized"
                android:value="true" />
        </activity>
    </application>
</manifest>
